# Set these on the Railway service (Variables tab).

# Auto-provided when a Postgres database is attached to this service and
# referenced (Railway: "Add variable reference" -> Postgres -> DATABASE_URL).
DATABASE_URL=postgresql://user:password@host:5432/railway

# Required. Any long random string (e.g. `openssl rand -hex 32`).
JWT_SECRET=

# The public URL Railway gives this service, e.g. https://housesitting.up.railway.app
# Used for CORS and for building links in outgoing emails.
FRONTEND_URL=

# Optional: transactional email (form invite emails). Leave blank to disable sending.
RESEND_API_KEY=
SENDER_EMAIL=onboarding@resend.dev

# Optional: seeded admin account (defaults shown).
ADMIN_EMAIL=admin@housesit.app
ADMIN_PASSWORD=admin123
